# Odoo MCP Server Configuration
# Copy this file to .env and update with your Odoo instance details
#
# =====================================================================
#  DEPLOIEMENT DOCKER + TRAEFIK  (lu par docker-compose.yml)
# =====================================================================
# Ces variables servent au compose pour s'integrer a ton Traefik.
# TRAEFIK_NETWORK et TRAEFIK_CERTRESOLVER ont deja les bons defauts
# (n8n_default / mytlschallenge), pas besoin de les remplir sauf cas particulier.

# Sous-domaine public qui pointera vers le MCP (DNS A/AAAA -> ton VPS)
MCP_DOMAIN=odoo-mcp.harmonixus.com

# Basic Auth Traefik (le transport MCP n'a AUCUNE auth integree !).
# Genere la valeur avec :   htpasswd -nbB monuser 'monMotDePasse'
# IMPORTANT compose : double chaque $ en $$  (ex: monuser:$$2y$$05$$....)
MCP_BASIC_AUTH=monuser:$$2y$$05$$REMPLACE_PAR_LE_HASH_HTPASSWD

# Surcharges optionnelles (decommente seulement si besoin) :
# TRAEFIK_NETWORK=n8n_default
# TRAEFIK_CERTRESOLVER=mytlschallenge

# =====================================================================
#  RACCOURCI ODOO SAAS (odoo.com online)  ->  YOLO mode obligatoire
# =====================================================================
# Sur le SaaS online tu ne peux pas installer le module mcp_server,
# donc on passe par les endpoints XML-RPC standards via YOLO.
#   ODOO_URL=https://tonentreprise.odoo.com
#   ODOO_DB=tonentreprise          # souvent = sous-domaine du SaaS
#   ODOO_API_KEY=...               # ta cle API admin
#   ODOO_USER=ton.email@domaine.com  # REQUIS en plus de la cle en YOLO
#   ODOO_YOLO=read                 # 'read' pour demarrer, 'true' pour CRUD
#   ODOO_MCP_ALLOWED_HOSTS=mcp-odoo.ton-domaine.com,localhost
# =====================================================================

# Server Configuration
# ====================

# Odoo server URL (required)
# The URL where your Odoo instance is running
ODOO_URL=http://localhost:8069

# Database name (optional)
# If not specified, will be auto-detected from Odoo
# ODOO_DB=your-database-name

# Authentication Configuration
# ============================

# Authentication method 1: API key (preferred)
# Generate in Odoo: Settings > Users & Companies > Users > API Keys
ODOO_API_KEY=your-api-key-here

# Authentication method 2: Username/password (fallback)
# Only used if ODOO_API_KEY is not provided
# ODOO_USER=your-username
# ODOO_PASSWORD=your-password

# Locale Configuration
# ====================

# Language/locale for Odoo responses (optional)
# When set, Odoo returns translated field labels, selection values, and messages
# Must be a locale installed in your Odoo instance (e.g. es_ES, fr_FR, de_DE)
# ODOO_LOCALE=es_ES

# YOLO Mode (Development/Testing Only!)
# ======================================

# Bypasses MCP module — connects directly to standard XML-RPC endpoints
# Valid values: off (default), read (read-only), true (full CRUD)
# ODOO_YOLO=off

# Enable the call_model_method tool (generic XML-RPC execute_kw escape hatch).
# Requires ODOO_YOLO=true; ignored otherwise. The tool can invoke any public
# Odoo method including destructive ones — enable only in trusted environments.
# ODOO_MCP_ENABLE_METHOD_CALLS=false

# Logging Configuration
# =====================

# Log level (optional)
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ODOO_MCP_LOG_LEVEL=INFO

# Enable structured JSON log output (optional)
# ODOO_MCP_LOG_JSON=false

# Path for rotating log file — 10 MB, 5 backups (optional)
# ODOO_MCP_LOG_FILE=/var/log/mcp-server-odoo.log

# Performance Configuration
# =========================

# Default pagination limit (optional)
# Number of records to return by default
# ODOO_MCP_DEFAULT_LIMIT=10

# Maximum pagination limit (optional)
# Maximum number of records that can be requested
# ODOO_MCP_MAX_LIMIT=100

# Maximum fields returned by smart field selection (optional)
# ODOO_MCP_MAX_SMART_FIELDS=15

# Transport Configuration
# =======================

# Transport type (optional)
# Valid values: stdio (default), streamable-http
# ODOO_MCP_TRANSPORT=stdio

# Server host for HTTP transport (optional)
# Only used when transport is streamable-http
# ODOO_MCP_HOST=localhost

# Server port for HTTP transport (optional)
# Only used when transport is streamable-http
# ODOO_MCP_PORT=8000

# Allowed Host headers for HTTP transport DNS-rebinding protection (optional)
# Comma-separated; set when running streamable-http behind a reverse proxy
# that forwards an external host. Unset = no host validation.
# ODOO_MCP_ALLOWED_HOSTS=odoo.example.com,localhost

# Seconds of inactivity before an HTTP session is closed (optional)
# Frees the session's server-side state. Unset = sessions never expire.
# ODOO_MCP_SESSION_IDLE_TIMEOUT=600